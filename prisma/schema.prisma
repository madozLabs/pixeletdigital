generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorldMode {
  ACTIVE
  TEASER
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AccessRole {
  SUPER_ADMIN
  ADMIN
  WORLD_MANAGER
  EDITOR
  SALES
  CONTRIBUTOR
  READER
}

enum AssignmentScopeType {
  GLOBAL
  WORLD
}

enum AuditAction {
  ACCESS_USER_CREATED
  ACCESS_USER_ACTIVATED
  ACCESS_USER_DEACTIVATED
  ACCESS_ROLE_ASSIGNED
  ACCESS_ROLE_REVOKED
}

enum AuditTargetType {
  USER
  ROLE_ASSIGNMENT
}

enum AuditResult {
  SUCCEEDED
}

enum RequestOriginChannel {
  WORKSPACE
  SYSTEM
}

enum AuthenticationEventType {
  SIGN_IN_SUCCEEDED
  SIGN_IN_FAILED
  SIGN_IN_REJECTED
  SIGN_OUT
}

enum AuthenticationFailureReason {
  INVALID_CREDENTIALS
  UNLINKED_IDENTITY
  INACTIVE_USER
  MISSING_ASSIGNMENT
  PROVIDER_ERROR
  SESSION_INVALID
}

enum ContentLifecycleState {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ServiceAvailabilityStatus {
  CANDIDATE
  CURRENT_STATED
  APPROVED_CURRENT
  FUTURE_ONLY
  WITHDRAWN
}

enum EnquiryType {
  GENERAL
}

enum EnquiryAbuseStatus {
  ACCEPTED
  FLAGGED
}

enum EditorialItemStatus {
  PLANNED
  DONE
  CANCELLED
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

enum CatalogueItemKind {
  SERVICE
  PRODUCT
}

enum CatalogueItemStatus {
  ACTIVE
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model World {
  id              String           @id @default(cuid())
  key             String           @unique
  displayName     String
  mode            WorldMode
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roleAssignments RoleAssignment[]
  auditEvents     AuditEvent[]
  pages           Page[]
  services        Service[]
  serviceFamilies ServiceFamily[]
  enquiries       Enquiry[]
  editorialItems  EditorialItem[]
  clients         Client[]
  catalogueItems  CatalogueItem[]
  invoices        Invoice[]

  @@map("worlds")
}

model User {
  id              String           @id @default(cuid())
  displayName     String?
  normalizedEmail String?          @unique
  status          UserStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  authAccounts    AuthAccount[]
  roleAssignments RoleAssignment[]

  @@map("users")
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  passwordHash      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model RoleAssignment {
  id         String              @id @default(cuid())
  userId     String
  role       AccessRole
  scopeType  AssignmentScopeType
  worldId    String?
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  world      World?              @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([userId, validFrom, validUntil])
  @@index([worldId])
  @@map("role_assignments")
}

model AuditEvent {
  id            String               @id
  occurredAt    DateTime
  actorId       String
  action        AuditAction
  targetType    AuditTargetType
  targetId      String
  result        AuditResult
  correlationId String
  originChannel RequestOriginChannel
  worldId       String?
  world         World?               @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@index([worldId, occurredAt])
  @@map("audit_events")
}

model AuthenticationEvent {
  id            String                       @id
  occurredAt    DateTime
  type          AuthenticationEventType
  userId        String?
  provider      String?
  reason        AuthenticationFailureReason?
  correlationId String
  originChannel RequestOriginChannel

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([type, occurredAt])
  @@map("authentication_events")
}

model Page {
  id          String                @id
  worldKey    String
  world       World                 @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  pageType    String
  title       String
  slug        String
  lifecycle   ContentLifecycleState
  version     Int
  publishedAt DateTime?
  createdAt   DateTime
  updatedAt   DateTime

  sections PageSection[]

  @@unique([worldKey, pageType, slug])
  @@index([worldKey, lifecycle])
  @@index([worldKey, slug, lifecycle])
  @@map("pages")
}

model PageSection {
  id                   String   @id
  pageId               String
  page                 Page     @relation(fields: [pageId], references: [id], onDelete: Restrict)
  sectionType          String
  order                Int
  payload              Json
  payloadSchemaVersion Int
  version              Int
  createdAt            DateTime
  updatedAt            DateTime

  @@index([pageId, order])
  @@map("page_sections")
}

model Service {
  id                 String                    @id
  worldKey           String
  world              World                     @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  familyId           String?
  family             ServiceFamily?            @relation(fields: [familyId], references: [id], onDelete: Restrict)
  name               String
  slug               String
  description        String
  availabilityStatus ServiceAvailabilityStatus
  lifecycle          ContentLifecycleState
  version            Int
  publishedAt        DateTime?
  createdAt          DateTime
  updatedAt          DateTime
  enquiries          Enquiry[]

  @@unique([worldKey, slug])
  @@index([worldKey, lifecycle])
  @@index([worldKey, availabilityStatus])
  @@index([worldKey, lifecycle, availabilityStatus])
  @@index([worldKey, slug, lifecycle])
  @@index([familyId])
  @@map("services")
}

model Enquiry {
  id             String              @id
  type           EnquiryType
  worldKey       String
  world          World               @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  serviceId      String?
  service        Service?            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  name           String
  email          String
  phone          String?
  message        String
  sourcePage     String
  idempotencyKey String              @unique
  abuseStatus    EnquiryAbuseStatus
  submittedAt    DateTime

  consent ConsentRecord?

  @@index([worldKey, email, submittedAt])
  @@index([worldKey, submittedAt])
  @@map("enquiries")
}

model ConsentRecord {
  id         String   @id
  enquiryId  String   @unique
  enquiry    Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Restrict)
  purposeKey String
  version    Int
  response   Boolean
  source     String
  capturedAt DateTime

  @@map("consent_records")
}

model ServiceFamily {
  id          String                @id
  worldKey    String
  world       World                 @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  label       String
  order       Int
  lifecycle   ContentLifecycleState
  version     Int
  publishedAt DateTime?
  createdAt   DateTime
  updatedAt   DateTime
  services    Service[]

  @@index([worldKey, order])
  @@index([worldKey, lifecycle])
  @@map("service_families")
}

model EditorialItem {
  id           String              @id
  worldKey     String
  world        World               @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  clientLabel  String
  channel      String
  title        String
  scheduledFor DateTime
  status       EditorialItemStatus
  proofUrl     String?
  notes        String?
  realizedAt   DateTime?
  version      Int
  createdAt    DateTime
  updatedAt    DateTime

  @@index([worldKey, scheduledFor])
  @@index([worldKey, status])
  @@map("editorial_items")
}

model Client {
  id        String       @id
  worldKey  String
  world     World        @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  name      String
  email     String?
  phone     String?
  address   String?
  status    ClientStatus
  version   Int
  createdAt DateTime
  updatedAt DateTime
  invoices  Invoice[]

  @@index([worldKey, status])
  @@map("clients")
}

model CatalogueItem {
  id             String              @id
  worldKey       String
  world          World               @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  label          String
  kind           CatalogueItemKind
  unitPriceCents Int
  status         CatalogueItemStatus
  version        Int
  createdAt      DateTime
  updatedAt      DateTime

  @@index([worldKey, status])
  @@map("catalogue_items")
}

model Invoice {
  id        String        @id
  worldKey  String
  world     World         @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  number    String
  status    InvoiceStatus
  issuedAt  DateTime
  version   Int
  createdAt DateTime
  updatedAt DateTime
  lines     InvoiceLine[]

  @@unique([worldKey, number])
  @@index([worldKey, status])
  @@map("invoices")
}

model InvoiceLine {
  id             String  @id
  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  label          String
  quantity       Int
  unitPriceCents Int
  order          Int

  @@index([invoiceId, order])
  @@map("invoice_lines")
}
