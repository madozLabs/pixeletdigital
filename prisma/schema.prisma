generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorldMode {
  ACTIVE
  TEASER
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AccessRole {
  SUPER_ADMIN
  ADMIN
  WORLD_MANAGER
  EDITOR
  SALES
  CONTRIBUTOR
  READER
}

enum AssignmentScopeType {
  GLOBAL
  WORLD
}

enum AuditAction {
  ACCESS_USER_CREATED
  ACCESS_USER_ACTIVATED
  ACCESS_USER_DEACTIVATED
  ACCESS_ROLE_ASSIGNED
  ACCESS_ROLE_REVOKED
}

enum AuditTargetType {
  USER
  ROLE_ASSIGNMENT
}

enum AuditResult {
  SUCCEEDED
}

enum RequestOriginChannel {
  WORKSPACE
  SYSTEM
}

enum AuthenticationEventType {
  SIGN_IN_SUCCEEDED
  SIGN_IN_FAILED
  SIGN_IN_REJECTED
  SIGN_OUT
}

enum AuthenticationFailureReason {
  INVALID_CREDENTIALS
  UNLINKED_IDENTITY
  INACTIVE_USER
  MISSING_ASSIGNMENT
  PROVIDER_ERROR
  SESSION_INVALID
}

enum ContentLifecycleState {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ServiceAvailabilityStatus {
  CANDIDATE
  CURRENT_STATED
  APPROVED_CURRENT
  FUTURE_ONLY
  WITHDRAWN
}

enum EnquiryType {
  GENERAL
}

enum EnquiryAbuseStatus {
  ACCEPTED
  FLAGGED
}

enum EditorialItemStatus {
  DRAFT
  INTERNAL_REVIEW
  CLIENT_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  CANCELLED
}

enum EditorialContentType {
  POST
  STORY
  REEL
  VIDEO
  ARTICLE
  EMAIL
  AD
  OTHER
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CatalogueItemKind {
  SERVICE
  PRODUCT
}

enum CatalogueItemStatus {
  ACTIVE
  ARCHIVED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
  CHEQUE
  OTHER
}

model World {
  id              String           @id @default(cuid())
  key             String           @unique
  displayName     String
  mode            WorldMode
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roleAssignments RoleAssignment[]
  auditEvents     AuditEvent[]
  projects        Project[]
  pages           Page[]
  services        Service[]
  serviceFamilies ServiceFamily[]
  enquiries       Enquiry[]
  editorialItems  EditorialItem[]
  clients         Client[]
  catalogueItems  CatalogueItem[]
  quotes          Quote[]
  invoices        Invoice[]
  mediaAssets     MediaAsset[]

  @@map("worlds")
}

model User {
  id              String             @id @default(cuid())
  displayName     String?
  normalizedEmail String?            @unique
  status          UserStatus
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  authAccounts    AuthAccount[]
  roleAssignments RoleAssignment[]
  memberships       TeamMembership[]
  managedClients     Client[]          @relation("ClientAccountManager")
  commercialClients Client[]          @relation("ClientCommercialOwner")
  managedProjects    Project[]         @relation("ProjectManager")
  assignedTasks      Task[]            @relation("TaskAssignee")
  createdTasks       Task[]            @relation("TaskCreator")
  editorialItems     EditorialItem[]    @relation("EditorialOwner")
  reviewedItems      EditorialItem[]    @relation("EditorialReviewer")

  @@map("users")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teams       Team[]

  @@map("departments")
}

model Team {
  id           String           @id @default(cuid())
  departmentId String
  name         String
  description  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  memberships  TeamMembership[]
  clients      Client[]
  projects     Project[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("teams")
}

model JobPosition {
  id          String           @id @default(cuid())
  title       String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships TeamMembership[]

  @@map("job_positions")
}

model TeamMembership {
  id            String       @id @default(cuid())
  userId        String
  teamId        String
  jobPositionId String?
  isPrimary     Boolean      @default(false)
  startedAt     DateTime     @default(now())
  endedAt       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: Restrict)

  @@index([userId, endedAt])
  @@index([teamId, endedAt])
  @@index([jobPositionId])
  @@map("team_memberships")
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  passwordHash      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model RoleAssignment {
  id         String              @id @default(cuid())
  userId     String
  role       AccessRole
  scopeType  AssignmentScopeType
  worldId    String?
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  world      World?              @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([userId, validFrom, validUntil])
  @@index([worldId])
  @@map("role_assignments")
}

model AuditEvent {
  id            String               @id
  occurredAt    DateTime
  actorId       String
  action        AuditAction
  targetType    AuditTargetType
  targetId      String
  result        AuditResult
  correlationId String
  originChannel RequestOriginChannel
  worldId       String?
  world         World?               @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@index([worldId, occurredAt])
  @@map("audit_events")
}

model AuthenticationEvent {
  id            String                       @id
  occurredAt    DateTime
  type          AuthenticationEventType
  userId        String?
  provider      String?
  reason        AuthenticationFailureReason?
  correlationId String
  originChannel RequestOriginChannel

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([type, occurredAt])
  @@map("authentication_events")
}

model Page {
  id          String                @id
  worldKey    String
  world       World                 @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  pageType    String
  title       String
  slug        String
  lifecycle   ContentLifecycleState
  version     Int
  publishedAt DateTime?
  createdAt   DateTime
  updatedAt   DateTime

  sections PageSection[]

  @@unique([worldKey, pageType, slug])
  @@index([worldKey, lifecycle])
  @@index([worldKey, slug, lifecycle])
  @@map("pages")
}

model PageSection {
  id                   String   @id
  pageId               String
  page                 Page     @relation(fields: [pageId], references: [id], onDelete: Restrict)
  sectionType          String
  order                Int
  payload              Json
  payloadSchemaVersion Int
  version              Int
  createdAt            DateTime
  updatedAt            DateTime

  @@index([pageId, order])
  @@map("page_sections")
}

model MediaAsset {
  id          String   @id @default(cuid())
  worldKey    String
  world       World    @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  bucket      String
  objectPath  String
  publicUrl   String
  title       String
  altText     String
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bucket, objectPath])
  @@index([worldKey, createdAt])
  @@index([worldKey, mimeType])
  @@map("media_assets")
}

model Service {
  id                 String                    @id
  worldKey           String
  world              World                     @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  familyId           String?
  family             ServiceFamily?            @relation(fields: [familyId], references: [id], onDelete: Restrict)
  name               String
  slug               String
  description        String
  availabilityStatus ServiceAvailabilityStatus
  lifecycle          ContentLifecycleState
  version            Int
  publishedAt        DateTime?
  createdAt          DateTime
  updatedAt          DateTime
  enquiries          Enquiry[]

  @@unique([worldKey, slug])
  @@index([worldKey, lifecycle])
  @@index([worldKey, availabilityStatus])
  @@index([worldKey, lifecycle, availabilityStatus])
  @@index([worldKey, slug, lifecycle])
  @@index([familyId])
  @@map("services")
}

model Enquiry {
  id             String              @id
  type           EnquiryType
  worldKey       String
  world          World               @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  serviceId      String?
  service        Service?            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  name           String
  email          String
  phone          String?
  message        String
  sourcePage     String
  idempotencyKey String              @unique
  abuseStatus    EnquiryAbuseStatus
  submittedAt    DateTime

  consent ConsentRecord?

  @@index([worldKey, email, submittedAt])
  @@index([worldKey, submittedAt])
  @@map("enquiries")
}

model ConsentRecord {
  id         String   @id
  enquiryId  String   @unique
  enquiry    Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Restrict)
  purposeKey String
  version    Int
  response   Boolean
  source     String
  capturedAt DateTime

  @@map("consent_records")
}

model ServiceFamily {
  id          String                @id
  worldKey    String
  world       World                 @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  label       String
  order       Int
  lifecycle   ContentLifecycleState
  version     Int
  publishedAt DateTime?
  createdAt   DateTime
  updatedAt   DateTime
  services    Service[]

  @@index([worldKey, order])
  @@index([worldKey, lifecycle])
  @@map("service_families")
}

model EditorialItem {
  id                String               @id
  worldKey          String
  clientId          String?
  projectId         String?
  ownerId           String?
  reviewerId        String?
  clientLabel       String
  channel           String
  contentType       EditorialContentType @default(POST)
  title             String
  brief             String?
  productionDueAt   DateTime?
  scheduledFor      DateTime
  status            EditorialItemStatus
  internalApprovedAt DateTime?
  clientApprovedAt  DateTime?
  proofUrl          String?
  notes             String?
  realizedAt        DateTime?
  version           Int
  createdAt         DateTime
  updatedAt         DateTime
  world             World                @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  client            Client?              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project           Project?             @relation(fields: [projectId], references: [id], onDelete: Restrict)
  owner             User?                @relation("EditorialOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviewer          User?                @relation("EditorialReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([worldKey, scheduledFor])
  @@index([worldKey, status])
  @@index([clientId, status])
  @@index([projectId])
  @@index([ownerId, status])
  @@map("editorial_items")
}

model Client {
  id                String       @id
  worldKey          String
  world             World        @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  name              String
  legalName         String?
  email             String?
  phone             String?
  address           String?
  website           String?
  logoUrl           String?
  industry          String?
  notes             String?
  accountManagerId  String?
  commercialOwnerId String?
  teamId            String?
  status            ClientStatus
  version           Int
  createdAt         DateTime
  updatedAt         DateTime
  accountManager    User?        @relation("ClientAccountManager", fields: [accountManagerId], references: [id], onDelete: Restrict)
  commercialOwner   User?        @relation("ClientCommercialOwner", fields: [commercialOwnerId], references: [id], onDelete: Restrict)
  team              Team?        @relation(fields: [teamId], references: [id], onDelete: Restrict)
  contacts          ClientContact[]
  projects          Project[]
  editorialItems    EditorialItem[]
  quotes            Quote[]
  invoices          Invoice[]

  @@index([worldKey, status])
  @@index([accountManagerId])
  @@index([commercialOwnerId])
  @@index([teamId])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isPrimary])
  @@map("client_contacts")
}

model Project {
  id               String          @id @default(cuid())
  worldKey         String
  clientId         String
  name             String
  description      String?
  status           ProjectStatus   @default(PLANNED)
  priority         ProjectPriority @default(NORMAL)
  projectManagerId String?
  teamId           String?
  budgetCents      Int?
  startDate        DateTime?
  dueDate          DateTime?
  progress         Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  world            World           @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectManager   User?           @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: Restrict)
  team             Team?           @relation(fields: [teamId], references: [id], onDelete: Restrict)
  tasks            Task[]
  editorialItems   EditorialItem[]

  @@index([worldKey, status])
  @@index([clientId, status])
  @@index([projectManagerId])
  @@index([teamId])
  @@index([dueDate])
  @@map("projects")
}

model Task {
  id               String       @id @default(cuid())
  projectId        String
  parentTaskId     String?
  dependencyTaskId String?
  title            String
  description      String?
  status           TaskStatus   @default(TODO)
  priority         TaskPriority @default(NORMAL)
  assigneeId       String?
  createdById      String?
  dueDate          DateTime?
  estimatedMinutes Int?
  actualMinutes    Int?
  progress         Int          @default(0)
  position         Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask       Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: Restrict)
  subtasks         Task[]       @relation("TaskHierarchy")
  dependencyTask   Task?        @relation("TaskDependency", fields: [dependencyTaskId], references: [id], onDelete: Restrict)
  dependentTasks   Task[]       @relation("TaskDependency")
  assignee         User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  createdBy        User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId, status, position])
  @@index([assigneeId, status])
  @@index([parentTaskId])
  @@index([dependencyTaskId])
  @@index([dueDate])
  @@map("tasks")
}

model CatalogueItem {
  id             String              @id
  worldKey       String
  world          World               @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  label          String
  kind           CatalogueItemKind
  unitPriceCents Int
  status         CatalogueItemStatus
  version        Int
  createdAt      DateTime
  updatedAt      DateTime

  @@index([worldKey, status])
  @@map("catalogue_items")
}

model Quote {
  id             String      @id @default(cuid())
  worldKey       String
  clientId       String
  number         String
  status         QuoteStatus @default(DRAFT)
  issuedAt       DateTime    @default(now())
  validUntil     DateTime?
  discountCents  Int         @default(0)
  taxRateBps     Int         @default(0)
  notes          String?
  convertedAt    DateTime?
  version        Int         @default(1)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  world          World       @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  client         Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lines          QuoteLine[]
  invoice        Invoice?

  @@unique([worldKey, number])
  @@index([worldKey, status])
  @@index([clientId, status])
  @@map("quotes")
}

model QuoteLine {
  id             String @id @default(cuid())
  quoteId        String
  label          String
  quantity       Int
  unitPriceCents Int
  order          Int
  quote          Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, order])
  @@map("quote_lines")
}

model Invoice {
  id             String        @id
  worldKey       String
  clientId       String
  quoteId        String?       @unique
  number         String
  status         InvoiceStatus
  issuedAt       DateTime
  dueAt          DateTime?
  discountCents  Int           @default(0)
  taxRateBps     Int           @default(0)
  notes          String?
  paidAt         DateTime?
  version        Int
  createdAt      DateTime
  updatedAt      DateTime
  world          World         @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  quote          Quote?        @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  lines          InvoiceLine[]
  payments       Payment[]

  @@unique([worldKey, number])
  @@index([worldKey, status])
  @@index([clientId, status])
  @@index([dueAt])
  @@map("invoices")
}

model InvoiceLine {
  id             String  @id
  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  label          String
  quantity       Int
  unitPriceCents Int
  order          Int

  @@index([invoiceId, order])
  @@map("invoice_lines")
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  amountCents Int
  method      PaymentMethod
  paidAt      DateTime      @default(now())
  reference   String?
  notes       String?
  createdAt   DateTime      @default(now())
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
  @@map("payments")
}
