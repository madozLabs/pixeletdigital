generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorldMode {
  ACTIVE
  TEASER
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AccessRole {
  SUPER_ADMIN
  ADMIN
  WORLD_MANAGER
  EDITOR
  SALES
  CONTRIBUTOR
  READER
}

enum AssignmentScopeType {
  GLOBAL
  WORLD
}

enum AuditAction {
  ACCESS_USER_CREATED
  ACCESS_USER_ACTIVATED
  ACCESS_USER_DEACTIVATED
  ACCESS_ROLE_ASSIGNED
  ACCESS_ROLE_REVOKED
}

enum AuditTargetType {
  USER
  ROLE_ASSIGNMENT
}

enum AuditResult {
  SUCCEEDED
}

enum RequestOriginChannel {
  WORKSPACE
  SYSTEM
}

enum AuthenticationEventType {
  SIGN_IN_SUCCEEDED
  SIGN_IN_FAILED
  SIGN_IN_REJECTED
  SIGN_OUT
}

enum AuthenticationFailureReason {
  INVALID_CREDENTIALS
  UNLINKED_IDENTITY
  INACTIVE_USER
  MISSING_ASSIGNMENT
  PROVIDER_ERROR
  SESSION_INVALID
}

enum PageLifecycleState {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model World {
  id              String           @id @default(cuid())
  key             String           @unique
  displayName     String
  mode            WorldMode
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roleAssignments RoleAssignment[]
  auditEvents     AuditEvent[]
  pages           Page[]

  @@map("worlds")
}

model User {
  id              String           @id @default(cuid())
  displayName     String?
  normalizedEmail String?          @unique
  status          UserStatus
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  authAccounts    AuthAccount[]
  roleAssignments RoleAssignment[]

  @@map("users")
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider           String
  providerAccountId  String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model RoleAssignment {
  id        String              @id @default(cuid())
  userId    String
  role      AccessRole
  scopeType AssignmentScopeType
  worldId   String?
  validFrom DateTime
  validUntil DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  world     World?              @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([userId, validFrom, validUntil])
  @@index([worldId])
  @@map("role_assignments")
}

model AuditEvent {
  id            String               @id
  occurredAt    DateTime
  actorId       String
  action        AuditAction
  targetType    AuditTargetType
  targetId      String
  result        AuditResult
  correlationId String
  originChannel RequestOriginChannel
  worldId       String?
  world         World?               @relation(fields: [worldId], references: [id], onDelete: Restrict)

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@index([worldId, occurredAt])
  @@map("audit_events")
}

model AuthenticationEvent {
  id            String                       @id
  occurredAt    DateTime
  type          AuthenticationEventType
  userId        String?
  provider      String?
  reason        AuthenticationFailureReason?
  correlationId String
  originChannel RequestOriginChannel

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([type, occurredAt])
  @@map("authentication_events")
}

model Page {
  id          String             @id
  worldKey    String
  world       World              @relation(fields: [worldKey], references: [key], onDelete: Restrict)
  pageType    String
  title       String
  slug        String
  lifecycle   PageLifecycleState
  version     Int
  publishedAt DateTime?
  createdAt   DateTime
  updatedAt   DateTime

  @@unique([worldKey, pageType, slug])
  @@index([worldKey, lifecycle])
  @@map("pages")
}
