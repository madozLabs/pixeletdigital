generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorldMode {
  ACTIVE
  TEASER
  INACTIVE
}

model World {
  id          String    @id @default(cuid())
  key         String    @unique
  displayName String
  mode        WorldMode
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("worlds")
}
